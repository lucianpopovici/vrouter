{
  "module": "ip",
  "version": "1.0",
  "keys": {
    "IPV4_FWD": {
      "type": "str", "description": "Enable global IPv4 packet forwarding",
      "default": "true", "choices": ["true", "false"],
      "mandatory": false, "group": "Forwarding"
    },
    "IPV6_FWD": {
      "type": "str", "description": "Enable global IPv6 packet forwarding",
      "default": "true", "choices": ["true", "false"],
      "mandatory": false, "group": "Forwarding"
    },
    "ECMP_HASH_MODE": {
      "type": "int", "description": "ECMP hash field bitmask (1=src_ip 2=dst_ip 4=src_port 8=dst_port 16=proto)",
      "default": 3, "min": 0, "max": 31,
      "mandatory": false, "group": "ECMP"
    },
    "DEFAULT_TTL": {
      "type": "int", "description": "Default TTL for originated IPv4 packets",
      "default": 64, "min": 1, "max": 255,
      "mandatory": false, "group": "Forwarding"
    }
  }
}

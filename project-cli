def main():
    import argparse
    p = argparse.ArgumentParser(
        prog="project-cli",
        description="Interactive project configuration shell",
    )
    p.add_argument("--socket",     default="/tmp/lldpd.sock",
                   help="IPC socket path (default: /tmp/lldpd.sock)")
    p.add_argument("--standalone", action="store_true",
                   help="Run without daemon (direct module access)")
    args = p.parse_args()

    adapter = _Adapter(args.socket, args.standalone)

    _print_banner(adapter)

    # Set up readline history
    histfile = os.path.expanduser("~/.project_cli_history")
    try:
        readline.read_history_file(histfile)
        readline.set_history_length(500)
    except FileNotFoundError:
        pass

    try:
        ProjectShell(adapter).cmdloop()
    except KeyboardInterrupt:
        print()
        print(_c("  Interrupted.", "grey"))
    finally:
        try:
            readline.write_history_file(histfile)
        except OSError:
            pass
        adapter.close()


if __name__ == "__main__":
    main()

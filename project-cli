class _FileAdapter:
    """
    Language-agnostic fallback adapter.

    Reads schema.json (written by any module at startup) and
    reads/writes runtime_config.json + interfaces.txt directly.

    Works with modules written in any language as long as they
    write a schema.json describing their configuration.

    Schema format (written by lldp/startup.py export_schema()):
    {
      "module": "lldp",
      "version": "1.0.21",
      "keys": {
        "TTL": {
          "type": "int", "description": "...",
          "default": 120, "min": 10, "max": 65535,
          "mandatory": true, "group": "Timing"
        }
      }
    }
    """

    def __init__(self, base_dir: str):
        self._base   = base_dir
        self._schema = self._load_schema()
        self._cfg    = os.path.join(base_dir, "runtime_config.json")
        self._ifaces = os.path.join(base_dir, "interfaces.txt")

    def _load_schema(self) -> dict:
        path = os.path.join(self._base, "schema.json")
        if not os.path.exists(path):
            return {}
        with open(path) as f:
            data = json.load(f)
        return data.get("keys", data)

    def _load_overrides(self) -> dict:
        if not os.path.exists(self._cfg):
            return {}
        try:
            with open(self._cfg) as f:
                return json.load(f)
        except (json.JSONDecodeError, OSError):
            return {}

    def _save_overrides(self, data: dict):
        with open(self._cfg, "w") as f:
            json.dump(data, f, indent=2)

    def _coerce(self, key: str, value):
        """Cast value to the type declared in schema.json."""
        entry = self._schema.get(key, {})
        typ   = entry.get("type", "str")
        lo    = entry.get("min")
        hi    = entry.get("max")

        if typ == "bool":
            if isinstance(value, bool):   return value
            if isinstance(value, str):
                if value.lower() in ("true",  "1", "yes", "on"):  return True
                if value.lower() in ("false", "0", "no",  "off"): return False
            if isinstance(value, int):    return bool(value)
            raise ValueError(f"Cannot convert {value!r} to bool")
        if typ == "int":
            v = int(value)
            if lo is not None and v < lo:
                raise ValueError(f"'{key}' minimum is {lo}, got {v}")
            if hi is not None and v > hi:
                raise ValueError(f"'{key}' maximum is {hi}, got {v}")
            return v
        return value

    # ── Schema ────────────────────────────────────────────────

    def get_schema(self) -> list:
        overrides = self._load_overrides()
        rows = []
        # Group by group field in schema
        from collections import defaultdict
        groups = defaultdict(list)
        for k, e in self._schema.items():
            groups[e.get("group", "Other")].append(k)

        group_order = list(dict.fromkeys(
            e.get("group", "Other") for e in self._schema.values()
        ))

        for group in group_order:
            for k in groups[group]:
                e       = self._schema[k]
                default = e.get("default")
                val     = overrides.get(k, default)
                try:
                    val = self._coerce(k, val) if val is not None else default
                except Exception:
                    pass
                rows.append({
                    "group":       group,
                    "key":         k,
                    "value":       val,
                    "type":        e.get("type", "str"),
                    "description": e.get("description", ""),
                    "min":         e.get("min"),
                    "max":         e.get("max"),
                    "mandatory":   e.get("mandatory", False),
                    "default":     default,
                })
        return rows

    # ── Config ops ────────────────────────────────────────────

    def config_get(self, key: str):
        key       = key.upper()
        overrides = self._load_overrides()
        if key in overrides:
            return overrides[key]
        entry = self._schema.get(key)
        if entry is None:
            raise KeyError(f"Unknown key '{key}'")
        return entry.get("default")

    def config_set(self, key: str, value):
        key   = key.upper()
        if key not in self._schema:
            raise KeyError(f"Unknown key '{key}'")
        coerced   = self._coerce(key, value)
        overrides = self._load_overrides()
        overrides[key] = coerced
        self._save_overrides(overrides)
        return coerced

    def config_del(self, key: str):
        key   = key.upper()
        entry = self._schema.get(key)
        if entry is None:
            raise KeyError(f"Unknown key '{key}'")
        overrides = self._load_overrides()
        overrides.pop(key, None)
        self._save_overrides(overrides)

    # ── Interfaces ────────────────────────────────────────────

    def interfaces_list(self) -> list:
        if not os.path.exists(self._ifaces):
            return []
        with open(self._ifaces) as f:
            return [l.strip() for l in f
                    if l.strip() and not l.strip().startswith("#")]

    def interfaces_add(self, name: str):
        ifaces = self.interfaces_list()
        if name not in ifaces:
            ifaces.append(name)
            _write_ifaces(self._ifaces, ifaces)

    def interfaces_remove(self, name: str):
        ifaces = self.interfaces_list()
        if name in ifaces:
            ifaces.remove(name)
            _write_ifaces(self._ifaces, ifaces)

    def neighbors_list(self):
        return None   # not available without daemon

    def close(self): pass


class _Adapter:
    """Thin wrapper — talks to daemon via IPC or module directly."""

    def __init__(self, socket_path: str, standalone: bool):
        self._standalone   = standalone
        self._socket_path  = socket_path
        self._sock         = None
        self._buf          = b""
        self._seq          = 0
        self._cm           = None
        self._cfg          = None
        self._groups       = None
        self._file_adapter = None   # tier-3: file-based

        if standalone:
            # Standalone: try Python direct, then file-based
            try:
                self._init_direct()
            except ImportError:
                base = os.path.dirname(os.path.abspath(self._socket_path))
                for candidate in [base, os.getcwd()]:
                    schema_path = os.path.join(candidate, "schema.json")
                    if os.path.exists(schema_path):
                        self._file_adapter = _FileAdapter(candidate)
                        print(_c(f"  ℹ Using file-based adapter "
                                 f"(schema.json found in {candidate})", "grey"))
                        break
        else:
            self._init_ipc()

    def _init_direct(self):
        from lldp import config_manager, config
        from lldp._config_groups import CONFIG_GROUPS
        from lldp.watcher import read_interfaces
        self._cm          = config_manager
        self._cfg         = config
        self._groups      = CONFIG_GROUPS
        self._read_ifaces = read_interfaces
        config_manager.load()

    def _init_ipc(self):
        """
        Three-tier fallback:
          1. IPC socket  — any language, daemon must be running
          2. Direct import — Python modules only, no daemon needed
          3. File-based  — any language, reads schema.json + config files
        """
        # Tier 1: IPC
        try:
            s = _sock.socket(_sock.AF_UNIX, _sock.SOCK_STREAM)
            s.settimeout(3)
            s.connect(self._socket_path)
            self._sock = s
            return
        except OSError:
            self._sock = None

        # Tier 2: Python direct import
        try:
            self._init_direct()
            self._file_adapter = None
            return
        except ImportError:
            pass

        # Tier 3: File-based (language-agnostic)
        base = os.path.dirname(os.path.abspath(self._socket_path))
        # Also check working directory
        for candidate in [base, os.getcwd()]:
            schema_path = os.path.join(candidate, "schema.json")
            if os.path.exists(schema_path):
                self._file_adapter = _FileAdapter(candidate)
                print(_c(f"  ℹ Using file-based adapter "
                         f"(schema.json found in {candidate})", "grey"))
                return

        # Nothing worked
        self._file_adapter = None
        print(_c("  ⚠ No daemon, no Python module, no schema.json found. "
                 "Limited functionality available.", "yellow"))

    @property
    def connected(self) -> bool:
        return self._sock is not None

    def _rpc(self, cmd: str, params: dict = None) -> object:
        if not self._sock:
            raise RuntimeError("No IPC connection")
        self._seq += 1
        req = json.dumps({"id": self._seq, "cmd": cmd,
                          "params": params or {}}) + "\n"
        self._sock.sendall(req.encode())
        while b"\n" not in self._buf:
            chunk = self._sock.recv(4096)
            if not chunk:
                raise ConnectionError("Server closed connection")
            self._buf += chunk
        line, self._buf = self._buf.split(b"\n", 1)
        resp = json.loads(line)
        if not resp.get("ok"):
            raise RuntimeError(resp.get("error", "unknown IPC error"))
        return resp.get("result")

    # ── Routing helper ────────────────────────────────────────

    def _call(self, ipc_cmd: str, ipc_params: dict,
              direct_fn, *direct_args, **direct_kwargs):
        """
        Route a call through the highest-priority available path:
          1. IPC socket  (any language, daemon running)
          2. Python direct import (Python only, no daemon)
          3. File-based adapter (any language, schema.json present)
        """
        # Tier 1: IPC
        if self._sock:
            try:
                return self._rpc(ipc_cmd, ipc_params)
            except (ConnectionError, OSError) as e:
                print(_c(f"  ⚠ IPC connection lost ({e}), "
                         f"falling back to next tier.", "yellow"))
                self._sock = None
                # Try to re-init direct or file
                try:
                    self._init_direct()
                except ImportError:
                    pass

        # Tier 2: Python direct import
        if self._cm is not None:
            return direct_fn(*direct_args, **direct_kwargs)

        # Tier 3: File-based
        if self._file_adapter is not None:
            # Map the call to the file adapter method
            return direct_fn(*direct_args, **direct_kwargs)

        raise RuntimeError(
            "No communication path available. "
            "Start the daemon, ensure the module is importable, "
            "or provide schema.json for file-based access."
        )

    # ── Schema ────────────────────────────────────────────────

    def get_schema(self) -> list:
        """
        Return full schema as list of dicts.
        In IPC mode: values come from the live daemon via config.show.
        In direct mode: values come from the live config module.
        """
        from lldp import config_manager
        from lldp._config_groups import CONFIG_GROUPS

        # Fetch live values (IPC or direct)
        if self._sock:
            try:
                live_rows = self._rpc("config.show")
                # live_rows is [{group, key, value, description}, ...]
                # Augment with type/bounds/mandatory/default from local schema
                live_map = {r["key"]: r["value"] for r in live_rows}
            except (ConnectionError, OSError):
                live_map = None
        else:
            live_map = None

        # Tier 3: file adapter
        if live_map is None and self._cm is None and self._file_adapter:
            return self._file_adapter.get_schema()

        rows = []
        for group, keys in CONFIG_GROUPS.items():
            for k in keys:
                if k not in config_manager.SCHEMA:
                    continue
                e   = config_manager.SCHEMA[k]
                val = live_map[k] if (live_map and k in live_map)                       else config_manager.get(k)
                rows.append({
                    "group":       group,
                    "key":         k,
                    "value":       val,
                    "type":        e[0].__name__,
                    "description": e[1],
                    "min":         e[2] if len(e) > 2 else None,
                    "max":         e[3] if len(e) > 3 else None,
                    "mandatory":   k in MANDATORY_KEYS,
                    "default":     _get_default(k),
                })
        return rows

    # ── Config ops ────────────────────────────────────────────

    def config_get(self, key: str):
        def _direct(k):
            if self._file_adapter:
                return self._file_adapter.config_get(k)
            from lldp import config_manager
            return config_manager.get(k)
        result = self._call("config.get", {"key": key}, _direct, key.upper())
        return result["value"] if isinstance(result, dict) else result

    def config_set(self, key: str, value: str):
        def _direct(k, v):
            if self._file_adapter:
                return self._file_adapter.config_set(k, v)
            from lldp import config_manager
            config_manager.set(k, v)
            return config_manager.get(k)
        result = self._call("config.set", {"key": key, "value": value},
                            _direct, key.upper(), value)
        return result["value"] if isinstance(result, dict) else result

    def config_del(self, key: str):
        """Reset a key to its default value (all three tiers)."""
        key = key.upper()
        if self._sock:
            default = _get_default(key)
            if default is None:
                raise KeyError(f"No default found for '{key}'")
            self._rpc("config.set", {"key": key, "value": default})
        elif self._file_adapter:
            self._file_adapter.config_del(key)
        else:
            from lldp import config_manager
            config_manager.reset(key)

    # ── Interfaces ────────────────────────────────────────────

    def interfaces_list(self) -> list:
        def _direct():
            if self._file_adapter:
                return self._file_adapter.interfaces_list()
            from lldp import config
            from lldp.watcher import read_interfaces
            return read_interfaces(config.INTERFACES_FILE)
        return self._call("interfaces.list", {}, _direct)

    def interfaces_add(self, name: str):
        def _direct(n):
            if self._file_adapter:
                return self._file_adapter.interfaces_add(n)
            from lldp.security import validate_iface_name
            from lldp import config
            from lldp.watcher import read_interfaces
            validate_iface_name(n)
            ifaces = read_interfaces(config.INTERFACES_FILE)
            if n not in ifaces:
                ifaces.append(n)
                _write_ifaces(config.INTERFACES_FILE, ifaces)
        self._call("interfaces.add", {"name": name}, _direct, name)

    def interfaces_remove(self, name: str):
        def _direct(n):
            if self._file_adapter:
                return self._file_adapter.interfaces_remove(n)
            from lldp import config
            from lldp.watcher import read_interfaces
            ifaces = read_interfaces(config.INTERFACES_FILE)
            if n in ifaces:
                ifaces.remove(n)
                _write_ifaces(config.INTERFACES_FILE, ifaces)
        self._call("interfaces.remove", {"name": name}, _direct, name)

    def neighbors_list(self) -> dict:
        if self._sock:
            return self._rpc("neighbors.list")
        return None   # not available without daemon

    def close(self):
        if self._sock:
            try: self._sock.close()
            except OSError: pass


def _write_ifaces(path, ifaces):
    with open(path, "w") as f:
        f.write("# interfaces.txt\n# One interface per line.\n")
        for n in ifaces:
            f.write(n + "\n")


# Cache of config.py defaults — parsed once with ast, never reloads the module
_DEFAULTS_CACHE: dict = {}

def _get_default(key: str):
    """
    Return the default value from config.py without reloading the module.
    Uses ast.literal_eval so live runtime state is never disturbed.
    """
    global _DEFAULTS_CACHE
    if not _DEFAULTS_CACHE:
        import ast as _ast, os as _os
        path = _os.path.join(_os.path.dirname(_os.path.abspath("project-cli")),
                             "lldp", "config.py")
        try:
            with open(path) as f:
                tree = _ast.parse(f.read())
            for node in _ast.walk(tree):
                if isinstance(node, _ast.Assign):
                    for target in node.targets:
                        if isinstance(target, _ast.Name):
                            try:
                                _DEFAULTS_CACHE[target.id] = _ast.literal_eval(node.value)
                            except (ValueError, TypeError):
                                pass
        except Exception:
            pass
    return _DEFAULTS_CACHE.get(key)



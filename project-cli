class ConfigShell(cmd.Cmd):
    """Intermediate config mode — choose which module to configure."""

    intro  = ""
    prompt = _c("project", "blue") + _c("(config)", "cyan") + "> "

    def __init__(self, adapter: _Adapter):
        super().__init__()
        self._adapter = adapter

    def do_common(self, _):
        """Enter shared project settings (SOCK_DIR, …)."""
        self._enter_module("common")

    def do_lldp(self, _):
        """Enter LLDP configuration area."""
        self._enter_module("lldp")

    def do_bfd(self, _):
        """Enter BFD configuration area."""
        self._enter_module("bfd")

    def _enter_module(self, name: str):
        print()
        print(_c(f"  Entering {name} configuration area.", "cyan"))
        print(_c("  Type 'info' for all keys, 'help' for commands, 'back' to return.", "grey"))
        print()
        try:
            from modules import get_adapter
            mod = get_adapter(name)
            ModuleConfigShell(name, mod).cmdloop()
        except Exception as e:
            _err(f"Could not load module '{name}': {e}")

    def do_example(self, _):
        """Enter example C module configuration area."""
        self._enter_module("example")

    def complete_show(self, text, line, bi, ei):
        try:
            from modules import REGISTRY
            opts = list(REGISTRY.keys())
        except ImportError:
            opts = list(MODULES.keys())
        return [o for o in opts if o.startswith(text)]

    def default(self, line: str):
        """Try to open any registered module by name."""
        name = line.split()[0].lower() if line.split() else ""
        try:
            from modules import REGISTRY
            if name in REGISTRY:
                self._enter_module(name)
                return
        except ImportError:
            pass
        _err(f"Unknown module '{name}'. "
             f"Type 'help' to see available modules.")

    def completenames(self, text, *ignored):
        # Built-in do_* completions
        names = [a[3:] for a in self.get_names() if a.startswith("do_" + text)]
        # All discovered module names
        try:
            from modules import discover
            names += [n for n in discover() if n.startswith(text) and n not in names]
        except ImportError:
            names += [n for n in MODULES if n.startswith(text) and n not in names]
        return names

    def do_help(self, arg: str):
        if arg:
            super().do_help(arg)
        else:
            _header("configure — Module Selection")
            print()
            print(_c("  Discovered modules:", "cyan"))
            for name, meta in _get_modules().items():
                print(f"    {_c(name, 'bold'):<20} {meta['description']}")
            print()
            print(_c("  Commands:", "cyan"))
            print(f"    {'<module>':<20} Enter that module's configuration area")
            print(f"    {'back / exit':<20} Return to top level")
            print()

    def do_back(self, _):
        """Return to the top-level shell."""
        return True

    def do_exit(self, _):
        """Return to the top-level shell."""
        return True

    def do_EOF(self, _):
        print()
        return True

    def default(self, line: str):
        name = line.split()[0].lower() if line.split() else line
        try:
            from modules import discover
            if name in discover():
                self._enter_module(name)
                return
        except ImportError:
            pass
        _err(f"Unknown module '{name}'. Type 'help' to see available modules.")

    def emptyline(self):
        pass


class ProjectShell(cmd.Cmd):
    """Top-level interactive project shell."""

    intro  = None
    prompt = _c("project", "blue") + "> "

    def __init__(self, adapter: _Adapter):
        super().__init__()
        self._adapter = adapter

    # ── configure ─────────────────────────────────────────────

    def do_configure(self, _):
        """Enter configuration mode. Then type a module name (e.g. lldp)."""
        print()
        print(_c("  Entering configuration mode.", "cyan"))
        print(_c("  Type a module name to configure it (e.g. 'lldp'), "
                 "'help' for options, 'back' to return.", "grey"))
        print()
        ConfigShell(self._adapter).cmdloop()

    # ── show ──────────────────────────────────────────────────

    def do_show(self, arg: str):
        """
show modules      List all discovered modules and their status.
show <module>     Show version and daemon status for a module.
        """
        arg = arg.strip().lower()

        if arg == "modules":
            _header("Discovered Modules")
            print()
            for name, meta in _get_modules().items():
                print(f"  {_c(name, 'bold'):<20} {meta['description']}")
            print()

        elif arg == "lldp":
            self._show_lldp()

        elif arg:
            discovered = _get_modules()
            if arg in discovered:
                self._show_generic_module(arg)
            else:
                _err(f"Unknown module '{arg}'. Try: show modules")

        else:
            _err("Usage: show modules  |  show <module>")

    def _show_lldp(self):
        from lldp import VERSION, PROTOCOL, DESCRIPTION

        # Daemon status
        active = self._adapter.connected
        if active:
            status_str = _c("● active (running)", "green")
        else:
            # Check if socket file exists but connection failed
            if os.path.exists(self._adapter._socket_path):
                status_str = _c("● socket exists but not reachable", "yellow")
            else:
                status_str = _c("○ inactive (no daemon / standalone mode)", "grey")

        # Interface count
        try:
            ifaces = self._adapter.interfaces_list()
            iface_str = ", ".join(ifaces) if ifaces else _c("none configured", "grey")
        except Exception:
            iface_str = _c("unavailable", "grey")

        # Neighbor count
        nb_str = _c("unavailable (standalone)", "grey")
        if active:
            try:
                nb = self._adapter.neighbors_list()
                nb_str = str(len(nb)) if nb is not None else nb_str
            except Exception:
                pass

        # Runtime config file
        try:
            from lldp import config as _cfg
            rc_path    = _cfg.RUNTIME_CONFIG
            rc_exists  = os.path.exists(rc_path)
            rc_str     = _c(rc_path, "cyan") + (
                _c(" (overrides active)", "yellow") if rc_exists else
                _c(" (not present — defaults only)", "grey"))
        except Exception:
            rc_str = _c("unavailable", "grey")

        _header("LLDP Module")
        print()
        _info(f"{'Version':<22}: {_c(VERSION, 'bold')}")
        _info(f"{'Protocol':<22}: {PROTOCOL}")
        _info(f"{'Description':<22}: {DESCRIPTION}")
        _info(f"{'Status':<22}: {status_str}")
        _info(f"{'Socket':<22}: {self._adapter._socket_path}")
        _info(f"{'Active interfaces':<22}: {iface_str}")
        _info(f"{'Neighbor count':<22}: {nb_str}")
        _info(f"{'Runtime config':<22}: {rc_str}")
        print()

    def _show_generic_module(self, name: str):
        try:
            from modules import get_adapter
            mod = get_adapter(name)
        except Exception as e:
            _err(f"Could not load module '{name}': {e}")
            return

        status_str = (_c("● active (running)", "green")
                      if mod.active
                      else _c("○ inactive (no daemon / file-based mode)", "grey"))

        _header(f"{name.upper()} Module")
        print()
        _info(f"{'Version':<22}: {_c(mod.version, 'bold')}")
        _info(f"{'Status':<22}: {status_str}")
        print()

    def complete_show(self, text, line, bi, ei):
        opts = ["modules"] + list(_get_modules().keys())
        return [o for o in opts if o.startswith(text)]

    # ── Misc ──────────────────────────────────────────────────

    def do_help(self, arg: str):
        if arg:
            super().do_help(arg)
        else:
            _header("project-cli Help")
            print()
            cmds = [
                ("show lldp",           "Show LLDP version and daemon status"),
                ("show modules",        "List all available modules"),
                ("configure",           "Enter configuration mode"),
                ("help [command]",      "Show this help or help for a command"),
                ("exit / quit",         "Exit the shell"),
            ]
            cfg_cmds = [
                ("lldp",                "Enter lldp module configuration area"),
                ("back",                "Return to top level"),
            ]
            lldp_cmds = [
                ("info",                "List all configurable keys"),
                ("info <KEY>",          "Details for a specific key"),
                ("show config",         "Display all parameters with current values"),
                ("get <KEY>",           "Get current value of a key"),
                ("set <KEY> <VALUE>",   "Change a key"),
                ("del <KEY>",           "Reset a key to default (mandatory blocked)"),
                ("back",                "Return to config mode"),
            ]
            print(_c("  Top-level commands:", "cyan"))
            for cmd_str, desc in cmds:
                print(f"    {cmd_str:<28} {desc}")
            print()
            print(_c("  Inside 'configure' mode:", "cyan"))
            for cmd_str, desc in cfg_cmds:
                print(f"    {cmd_str:<28} {desc}")
            print()
            print(_c("  Inside module config area (e.g. lldp):", "cyan"))
            for cmd_str, desc in lldp_cmds:
                print(f"    {cmd_str:<28} {desc}")
            print()

    def do_exit(self, _):
        """Exit the shell."""
        print(_c("  Goodbye.", "grey"))
        return True

    def do_quit(self, _):
        """Exit the shell."""
        return self.do_exit(_)

    def do_EOF(self, _):
        print()
        return self.do_exit(_)

    def default(self, line: str):
        cmd = line.split()[0] if line.split() else line
        _err(f"Unknown command '{cmd}'. Type 'help' for available commands.")

    def emptyline(self):
        pass



def _print_banner(adapter: _Adapter):
    w = min(shutil.get_terminal_size().columns, 70)
    print()
    print(_c("  ┌" + "─" * (w - 4) + "┐", "blue"))
    title = "project-cli"
    pad   = (w - 4 - len(title)) // 2
    print(_c("  │" + " " * pad + title + " " * (w - 4 - pad - len(title)) + "│", "blue"))
    print(_c("  └" + "─" * (w - 4) + "┘", "blue"))
    print()

    # Quick status line
    if adapter.connected:
        mode = _c("● IPC — connected to daemon at " + adapter._socket_path, "green")
    elif adapter._cm is not None:
        mode = _c("● Direct — Python module (no daemon needed)", "cyan")
    elif adapter._file_adapter is not None:
        mode = _c("● File-based — language-agnostic (schema.json)", "yellow")
    else:
        mode = _c("✗ No communication path available", "red")
    print(f"  Mode: {mode}")
    print(_c("  Type 'help' for commands. Tab completion available.", "grey"))
    print()


# ══════════════════════════════════════════════════════════════
#  Entry point
# ══════════════════════════════════════════════════════════════

def main():
    import argparse
    p = argparse.ArgumentParser(
        prog="project-cli",
        description="Interactive project configuration shell",
    )
    p.add_argument("--socket",     default="/tmp/lldpd.sock",
                   help="IPC socket path (default: /tmp/lldpd.sock)")
    p.add_argument("--standalone", action="store_true",
                   help="Run without daemon (direct module access)")
    args = p.parse_args()

    adapter = _Adapter(args.socket, args.standalone)

    _print_banner(adapter)

    # Set up readline history
    histfile = os.path.expanduser("~/.project_cli_history")
    try:
        readline.read_history_file(histfile)
        readline.set_history_length(500)
    except FileNotFoundError:
        pass

    try:
        ProjectShell(adapter).cmdloop()
    except KeyboardInterrupt:
        print()
        print(_c("  Interrupted.", "grey"))
    finally:
        try:
            readline.write_history_file(histfile)
        except OSError:
            pass
        adapter.close()


if __name__ == "__main__":
    main()

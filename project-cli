    def do_address(self, arg: str):
        """
address show [<ifindex>]             List addresses (optionally per interface).
address add <ifindex> <prefix/len>   Assign an address to an interface.
address del <ifindex> <prefix/len>   Remove an address from an interface.

Examples:
  address show
  address show 2
  address add 2 192.168.1.1/24
  address del 2 192.168.1.1/24
        """
        parts = arg.split()
        sub   = parts[0].lower() if parts else ""

        if sub == "show":
            params: dict = {}
            if len(parts) > 1:
                try: params["ifindex"] = int(parts[1])
                except ValueError: _err("ifindex must be an integer"); return
            resp = self._mod.op("list_addrs", **params)
            if not _resp_ok(resp): return
            addrs = resp.get("addresses", [])
            if not addrs: _info("No addresses configured."); return
            _tbl(["IFINDEX", "INTERFACE", "PREFIX"],
                 [[a.get("ifindex",""), a.get("ifname",""), a.get("prefix","")]
                  for a in addrs], [10, 18, 24])

        elif sub == "add":
            if len(parts) < 3: _err("Usage: address add <ifindex> <prefix/len>"); return
            try: ifindex = int(parts[1])
            except ValueError: _err("ifindex must be an integer"); return
            resp = self._mod.op("add_addr", ifindex=ifindex, prefix=parts[2])
            if _resp_ok(resp): _ok(f"address {parts[2]} assigned to ifindex {ifindex}")

        elif sub == "del":
            if len(parts) < 3: _err("Usage: address del <ifindex> <prefix/len>"); return
            try: ifindex = int(parts[1])
            except ValueError: _err("ifindex must be an integer"); return
            resp = self._mod.op("del_addr", ifindex=ifindex, prefix=parts[2])
            if _resp_ok(resp): _ok(f"address {parts[2]} removed from ifindex {ifindex}")

        else:
            _err("Usage: address show|add|del  (type 'help address')")

    def complete_address(self, text, line, bi, ei):
        return [s for s in ["show", "add", "del"] if s.startswith(text)]

    def do_interface(self, arg: str):
        """
interface show    List tracked interfaces with forwarding state and address count.
        """
        if arg.strip().lower() != "show":
            _err("Usage: interface show"); return
        resp = self._mod.op("list_interfaces")
        if not _resp_ok(resp): return
        ifaces = resp.get("interfaces", [])
        if not ifaces: _info("No interfaces tracked."); return
        _tbl(["IFINDEX", "NAME", "MTU", "IPv4 FWD", "IPv6 FWD", "ADDRS"],
             [[i.get("ifindex",""), i.get("name",""), i.get("mtu",""),
               "on" if i.get("ip4_fwd") else "off",
               "on" if i.get("ip6_fwd") else "off",
               i.get("n_addrs","")]
              for i in ifaces], [10, 18, 8, 10, 10, 6])

    def complete_interface(self, text, line, bi, ei):
        return [s for s in ["show"] if s.startswith(text)]

    def do_route(self, arg: str):
        """
route show [ipv4|ipv6]                                    List routes.
route add <prefix> nexthop <ip> ifindex <n> [metric <m>]  Add a static route.
route del <prefix>                                        Remove a route.

Examples:
  route show
  route show ipv4
  route add 10.0.0.0/24 nexthop 192.168.1.1 ifindex 2
  route del 10.0.0.0/24
        """
        parts = arg.split()
        sub   = parts[0].lower() if parts else ""

        if sub == "show":
            params: dict = {}
            if len(parts) > 1: params["af"] = parts[1].lower()
            resp = self._mod.op("list_routes", **params)
            if not _resp_ok(resp): return
            routes = resp.get("routes", [])
            if not routes: _info("No routes."); return
            rows = []
            for r in routes:
                for p in r.get("paths", [{}]):
                    rows.append([r.get("prefix",""), p.get("nexthop","—"),
                                 p.get("ifindex",""), r.get("ad",""),
                                 r.get("metric",""), p.get("weight",1)])
            _tbl(["PREFIX", "NEXTHOP", "IFINDEX", "AD", "METRIC", "W"],
                 rows, [24, 22, 10, 5, 8, 3])

        elif sub == "add":
            p = parts
            try:
                prefix  = p[1]
                nh_i    = p.index("nexthop")
                if_i    = p.index("ifindex")
                nexthop = p[nh_i + 1]
                ifindex = int(p[if_i + 1])
            except (ValueError, IndexError):
                _err("Usage: route add <prefix> nexthop <ip> ifindex <n> [metric <m>]")
                return
            params: dict = dict(prefix=prefix, nexthop=nexthop, ifindex=ifindex)
            try: params["metric"] = int(p[p.index("metric") + 1])
            except (ValueError, IndexError): pass
            try: params["ad"] = int(p[p.index("ad") + 1])
            except (ValueError, IndexError): pass
            resp = self._mod.op("add_route", **params)
            if _resp_ok(resp): _ok(f"route {prefix} via {nexthop} ifindex {ifindex}")

        elif sub == "del":
            if len(parts) < 2: _err("Usage: route del <prefix>"); return
            resp = self._mod.op("del_route", prefix=parts[1])
            if _resp_ok(resp): _ok(f"route {parts[1]} removed")

        else:
            _err("Usage: route show|add|del  (type 'help route')")

    def complete_route(self, text, line, bi, ei):
        return [s for s in ["show", "add", "del"] if s.startswith(text)]



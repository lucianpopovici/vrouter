class _BfdAdapter:
    """Adapter for the BFD daemon (Python), bridging BFDClient to ModuleConfigShell."""

    VERSION = "unknown"

    _TYPE_META = {
        "DESIRED_MIN_TX_US":  {"type":"int","min":10000,"max":60000000,
                               "group":"Timers","description":"Desired min TX interval (µs)"},
        "REQUIRED_MIN_RX_US": {"type":"int","min":10000,"max":60000000,
                               "group":"Timers","description":"Required min RX interval (µs)"},
        "DETECT_MULT":        {"type":"int","min":1,"max":255,
                               "group":"Timers","description":"Detection time multiplier"},
        "MAX_SESSIONS":       {"type":"int","min":1,"max":1024,
                               "group":"Session","description":"Maximum concurrent BFD sessions"},
        "DEFAULT_AUTH_TYPE":  {"type":"str","group":"Session",
                               "description":"Authentication type (none/md5/sha1)"},
        "ECHO_ENABLED":       {"type":"bool","group":"Session",
                               "description":"Enable BFD echo mode"},
        "LOG_LEVEL":          {"type":"str","group":"Logging",
                               "description":"Log level (DEBUG/INFO/WARNING/ERROR)"},
        "LOG_STATE_CHANGES":  {"type":"bool","group":"Logging",
                               "description":"Log BFD state transitions"},
    }

    def __init__(self):
        try:
            import importlib
            v = importlib.import_module("bfd.__version__")
            self.VERSION = getattr(v, "VERSION", "unknown")
        except ImportError:
            pass
        self._client = None
        try:
            from bfd.client import BFDClient
            self._client = BFDClient()
        except ImportError:
            pass

    @property
    def version(self): return self.VERSION

    @property
    def active(self) -> bool:
        if not self._client: return False
        try:
            return bool(self._client.ping().get("ok"))
        except Exception:
            return False

    def schema_rows(self) -> list:
        try:
            from bfd.config import DEFAULTS
            from bfd._config_groups import DISPLAY_GROUPS
        except ImportError:
            return []
        rows = []
        for group, keys in DISPLAY_GROUPS.items():
            for key in keys:
                meta    = self._TYPE_META.get(key, {"type":"str","group":group,"description":""})
                default = DEFAULTS.get(key)
                val     = default
                try:
                    if self._client:
                        resp = self._client.config_get(key)
                        if resp.get("ok") and "value" in resp:
                            val = resp["value"]
                except Exception:
                    pass
                rows.append({
                    "group":       meta.get("group", group),
                    "key":         key,
                    "value":       val,
                    "type":        meta.get("type", "str"),
                    "description": meta.get("description", ""),
                    "min":         meta.get("min"),
                    "max":         meta.get("max"),
                    "mandatory":   False,
                    "default":     default,
                })
        return rows

    def get(self, key: str):
        if not self._client: raise RuntimeError("BFD daemon not running")
        resp = self._client.config_get(key)
        if resp.get("ok"): return resp.get("value")
        raise KeyError(f"{key}: {resp.get('error', str(resp))}")

    def set(self, key: str, value: str):
        if not self._client: raise RuntimeError("BFD daemon not running")
        try:
            from bfd.config import validate, DEFAULTS
            default = DEFAULTS.get(key.upper())
            if isinstance(default, bool):
                coerced = value.lower() in ("true", "1", "yes", "on")
            elif isinstance(default, int):
                coerced = int(value)
            else:
                coerced = value
            ok, err = validate(key, coerced)
            if not ok: raise ValueError(err)
        except ImportError:
            coerced = value
        resp = self._client.config_set(key, coerced)
        if not resp.get("ok"):
            raise ValueError(resp.get("error", "failed"))

    def reset(self, key: str):
        if not self._client: raise RuntimeError("BFD daemon not running")
        resp = self._client.config_reset(key)
        if not resp.get("ok"):
            raise ValueError(resp.get("error", "failed"))

    def session_show(self, peer_ip=None):
        if not self._client: raise RuntimeError("BFD daemon not running")
        return self._client.session_show(peer_ip)

    def session_add(self, peer_ip: str, **kwargs):
        if not self._client: raise RuntimeError("BFD daemon not running")
        return self._client.session_add(peer_ip, **kwargs)

    def session_del(self, peer_ip: str):
        if not self._client: raise RuntimeError("BFD daemon not running")
        return self._client.session_del(peer_ip)


class BfdConfigShell(ModuleConfigShell):
    """BFD module shell — config keys + session management."""

    def __init__(self):
        super().__init__("bfd", _BfdAdapter())

    def do_session(self, arg: str):
        """
session show [<peer_ip>]                                              Show sessions.
session add <peer_ip> [local <ip>] [tx <us>] [rx <us>] [mult <n>]  Add a session.
session del <peer_ip>                                                 Delete a session.

Examples:
  session show
  session show 10.0.0.2
  session add 10.0.0.2
  session add 10.0.0.2 local 10.0.0.1 tx 300000 rx 300000 mult 3
  session del 10.0.0.2
        """
        parts = arg.split()
        sub   = parts[0].lower() if parts else ""

        if sub == "show":
            peer = parts[1] if len(parts) > 1 else None
            try:
                resp = self._mod.session_show(peer)
            except Exception as e: _err(str(e)); return
            if not resp.get("ok"): _err(resp.get("error","failed")); return
            sessions = resp.get("sessions", [])
            if isinstance(sessions, dict): sessions = list(sessions.values())
            if not sessions: _info("No BFD sessions."); return
            _tbl(["PEER_IP", "LOCAL_IP", "STATE", "TX_US", "RX_US", "MULT"],
                 [[s.get("peer_ip",""), s.get("local_ip",""), s.get("state",""),
                   s.get("desired_min_tx_us",""), s.get("required_min_rx_us",""),
                   s.get("detect_mult","")]
                  for s in sessions], [18, 18, 10, 10, 10, 5])

        elif sub == "add":
            if len(parts) < 2:
                _err("Usage: session add <peer_ip> [local <ip>] [tx <us>] [rx <us>] [mult <n>]")
                return
            peer_ip = parts[1]
            kwargs: dict = {}
            try:
                if "local" in parts: kwargs["local_ip"]            = parts[parts.index("local") + 1]
                if "tx"    in parts: kwargs["desired_min_tx_us"]   = int(parts[parts.index("tx")   + 1])
                if "rx"    in parts: kwargs["required_min_rx_us"]  = int(parts[parts.index("rx")   + 1])
                if "mult"  in parts: kwargs["detect_mult"]         = int(parts[parts.index("mult") + 1])
            except (ValueError, IndexError):
                _err("Invalid arguments"); return
            try:
                resp = self._mod.session_add(peer_ip, **kwargs)
            except Exception as e: _err(str(e)); return
            if resp.get("ok"): _ok(f"session to {peer_ip} created")
            else: _err(resp.get("error", "failed"))

        elif sub == "del":
            if len(parts) < 2: _err("Usage: session del <peer_ip>"); return
            try:
                resp = self._mod.session_del(parts[1])
            except Exception as e: _err(str(e)); return
            if resp.get("ok"): _ok(f"session to {parts[1]} deleted")
            else: _err(resp.get("error", "failed"))

        else:
            _err("Usage: session show|add|del  (type 'help session')")

    def complete_session(self, text, line, bi, ei):
        return [s for s in ["show", "add", "del"] if s.startswith(text)]



class ModuleConfigShell(cmd.Cmd):
    """
    Generic interactive config shell for any module (lldp, C modules, etc.)
    Driven entirely by the module's adapter — no module-specific code here.
    """

    intro  = ""

    def __init__(self, module_name: str, module_adapter):
        super().__init__()
        self._name    = module_name
        self._mod     = module_adapter          # ModuleAdapter instance
        self._schema  = None                    # cached on first use
        self.prompt   = (_c("project", "blue") +
                         _c(f"(config-{module_name})", "cyan") + "> ")

    def _get_schema(self) -> list:
        if self._schema is None:
            self._schema = self._mod.schema_rows()
        return self._schema

    def _all_keys(self) -> list[str]:
        return [r["key"] for r in self._get_schema()]

    def _invalidate_cache(self):
        self._schema = None

    def _mandatory_keys(self) -> set:
        return {r["key"] for r in self._get_schema() if r.get("mandatory")}


    # ── Tab completion helpers ────────────────────────────────

    def _complete_key(self, text: str) -> list[str]:
        return [k for k in self._all_keys() if k.startswith(text.upper())]

    def complete_get(self, text, line, bi, ei):
        return self._complete_key(text)

    def complete_set(self, text, line, bi, ei):
        parts = line.split()
        if len(parts) <= 1 or (len(parts) == 2 and not line.endswith(" ")):
            return self._complete_key(text)
        # Suggest bool values
        key = parts[1].upper() if len(parts) > 1 else ""
        schema = {r["key"]: r for r in self._get_schema()}
        if key in schema and schema[key]["type"] == "bool":
            return [v for v in ["true", "false"] if v.startswith(text.lower())]
        return []

    def complete_del(self, text, line, bi, ei):
        mandatory = self._mandatory_keys()
        return [r["key"] for r in self._get_schema()
                if r["key"].startswith(text.upper())
                and r["key"] not in mandatory]

    def complete_info(self, text, line, bi, ei):
        return self._complete_key(text)

    # ── Commands ──────────────────────────────────────────────

    def do_info(self, arg: str):
        """
info              List all configurable keys with type, bounds and description.
info <KEY>        Show full details for a specific key.
        """
        rows = self._get_schema()
        if not rows:
            _warn(f"'{self._name}' has no configurable parameters.")
            return
        _print_info_table(rows, arg.strip() if arg.strip() else None)

    def do_show(self, arg: str):
        """
show config       Display all parameters with current and default values.
        """
        arg = arg.strip().lower()
        if arg == "config":
            rows = self._get_schema()
            if not rows:
                _warn(f"'{self._name}' has no configurable parameters.")
                return
            _print_config_table(rows)
        else:
            _err(f"Unknown show subcommand '{arg}'. Try: show config")

    def do_get(self, arg: str):
        """
get <KEY>         Display the current value of a configuration key.

Example:
  get TTL
  get SEND_INTERVAL
        """
        key = arg.strip().upper()
        if not key:
            _err("Usage: get <KEY>")
            return
        try:
            val = self._mod.get(key)
            print()
            print(f"  {_c(key, 'bold')} = {_c(str(val), 'yellow')}")
            print()
        except (KeyError, RuntimeError) as e:
            _err(str(e))

    def do_set(self, arg: str):
        """
set <KEY> <VALUE>  Change a configuration key.

Examples:
  set TTL 60
  set SEND_INTERVAL 15
  set TLV_DOT3_POE_ENABLED true
  set MAX_NEIGHBORS_PER_INTERFACE 16
        """
        parts = arg.split(None, 1)
        if len(parts) < 2:
            _err("Usage: set <KEY> <VALUE>")
            return
        key, value = parts[0].upper(), parts[1].strip()
        try:
            self._mod.set(key, value)
            val = self._mod.get(key)
            self._invalidate_cache()
            _ok(f"{key} = {val}")
        except (KeyError, ValueError, RuntimeError) as e:
            _err(str(e))

    def do_del(self, arg: str):
        """
del <KEY>         Reset a key to its default value.
                  Mandatory keys (SEND_INTERVAL, TTL, etc.) cannot be deleted.

Examples:
  del TLV_DOT3_POE_ENABLED
  del DISPLAY_INTERVAL
        """
        key = arg.strip().upper()
        if not key:
            _err("Usage: del <KEY>")
            return
        mandatory = self._mandatory_keys()
        if key in mandatory:
            _err(f"'{key}' is a mandatory key and cannot be deleted.")
            _warn(f"Use 'set {key} <value>' to change it instead.")
            return
        schema = {r["key"]: r for r in self._get_schema()}
        if key not in schema:
            _err(f"Unknown key '{key}'")
            return
        try:
            default = schema[key].get("default")
            self._mod.reset(key)
            self._invalidate_cache()
            _ok(f"{key} reset to default: {default}")
        except (KeyError, ValueError) as e:
            _err(str(e))

    def do_back(self, _):
        """Return to the top-level shell."""
        return True

    def do_exit(self, _):
        """Return to the top-level shell."""
        return True

    def do_EOF(self, _):
        print()
        return True

    def default(self, line: str):
        _err(f"Unknown command '{line.split()[0]}'. Type 'help' for available commands.")

    def emptyline(self):
        pass   # don't repeat last command on empty enter


#  Operational helpers shared by module shells
# ══════════════════════════════════════════════════════════════

def _resp_ok(resp: dict, noun: str = "") -> bool:
    if resp.get("status") == "ok":
        return True
    msg = resp.get("message", resp.get("msg", "operation failed"))
    _err(f"{noun + ': ' if noun else ''}{msg}")
    return False


def _tbl(headers: list, rows: list, col_widths: list = None):
    """Print a fixed-width table."""
    widths = col_widths or [
        max(len(str(h)), max((len(str(r[i])) for r in rows), default=0)) + 2
        for i, h in enumerate(headers)
    ]
    fmt = "  " + "".join(f"{{:<{w}}}" for w in widths)
    print()
    print(fmt.format(*headers))
    print("  " + "".join("─" * w for w in widths))
    for r in rows:
        print(fmt.format(*[str(v) for v in r]))
    print()



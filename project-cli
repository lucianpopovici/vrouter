class _LegacyLldpAdapter:
    """Fallback when modules/ is not available — uses _Adapter directly."""
    def __init__(self, adapter):
        self._a = adapter
        sys.path.insert(0, _DIR)
        try:
            from lldp import config_manager, config
            from lldp._config_groups import CONFIG_GROUPS
            from lldp.__version__ import VERSION
            self._cm      = config_manager
            self._cfg     = config
            self._groups  = CONFIG_GROUPS
            self._version = VERSION
            config_manager.load()
        except ImportError:
            self._cm = self._cfg = self._groups = None
            self._version = "unknown"
        from modules.base import ModuleAdapter
        self.SCHEMA         = {}
        self.MANDATORY_KEYS = set()
        self.VERSION        = self._version

    @property
    def version(self): return self._version
    @property
    def active(self): return self._a.connected

    def get(self, key):   return self._a.config_get(key)["value"]
    def set(self, key, v): self._a.config_set(key, v)
    def reset(self, key): self._a.config_del(key)
    def config_snapshot(self):
        if not self._cm: return {}
        return {k: self._cm.get(k) for k in self._cm.SCHEMA}

    def schema_rows(self):
        rows = self._a.get_schema()
        for r in rows:
            r.setdefault("mandatory", r["key"] in MANDATORY_KEYS)
            r.setdefault("default", None)
        return rows



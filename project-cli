#!/usr/bin/env python3
# project-cli — Interactive project configuration shell
#
# Usage:
#   ./project-cli                      interactive mode
#   ./project-cli --standalone         no daemon needed
#   ./project-cli --socket /tmp/x.sock custom socket
#
# Once inside:
#   project> show lldp                 version + daemon status
#   project> show modules              list available modules
#   project> lldp                      enter lldp config mode
#   project(lldp)> info                list all keys
#   project(lldp)> info TTL            details for TTL
#   project(lldp)> show config         current values
#   project(lldp)> get TTL             get one value
#   project(lldp)> set TTL 60          change a value
#   project(lldp)> del TTL             reset to default
#   project(lldp)> back                return to top level


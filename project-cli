def _fmt_type(entry: dict) -> str:
    typ = entry.get("type", "")
    lo  = entry.get("min")
    hi  = entry.get("max")
    if lo is not None and hi is not None:
        return f"{typ} [{lo}–{hi}]"
    if lo is not None:
        return f"{typ} [min {lo}]"
    if hi is not None:
        return f"{typ} [max {hi}]"
    return typ


def _print_info_table(rows: list, filter_key: str = None):
    """Print grouped info table of all keys."""
    if filter_key:
        rows = [r for r in rows if r["key"].upper() == filter_key.upper()]
        if not rows:
            _err(f"Unknown key '{filter_key}'")
            return
        # Single key — detailed view
        r = rows[0]
        _header(f"Key: {r['key']}")
        print()
        _info(f"{'Group':<18}: {_c(r['group'], 'cyan')}")
        _info(f"{'Description':<18}: {r['description']}")
        _info(f"{'Type':<18}: {_fmt_type(r)}")
        cur_str = _c(str(r['value']), 'yellow')
        _info(f"{'Current value':<18}: {cur_str}")
        def_str = _c(str(r['default']), 'grey')
        _info(f"{'Default value':<18}: {def_str}")
        mand = _c("Yes — cannot be deleted", "red") if r['mandatory'] \
               else _c("No", "green")
        _info(f"{'Mandatory':<18}: {mand}")
        print()
        return

    group = None
    KW = 38
    print()
    for r in rows:
        row_group = r.get("group", "")
        if row_group != group:
            group = row_group
            if group:
                print(_c(f"\n  ▸ {group}", "cyan"))
            print(_c(f"  {'Key':<{KW}} {'Type':<20} Description", "grey"))
            print(_c(f"  {'─'*78}", "grey"))

        key_str = _c(r["key"], "bold") if r["mandatory"] else r["key"]
        mand    = _c(" *", "red") if r["mandatory"] else "  "
        print(f"  {key_str + mand:<{KW+10}} {_fmt_type(r):<20} {r['description']}")
    print()
    print(_c("  * = mandatory key (del not allowed)", "grey"))
    print()


def _print_config_table(rows: list):
    """Print grouped config table with current + default values."""
    _header("Current Configuration")
    group = None
    KW = 36
    VW = 12
    print()
    for r in rows:
        row_group = r.get("group", "")
        if row_group != group:
            group = row_group
            if group:
                print(_c(f"\n  ▸ {group}", "cyan"))
            print(_c(f"  {'Key':<{KW}} {'Value':<{VW}} Default", "grey"))
            print(_c(f"  {'─'*70}", "grey"))

        val     = r["value"]
        default = r["default"]
        changed = str(val) != str(default)

        val_str = _c(str(val), "yellow") if changed else str(val)
        def_str = _c(str(default), "grey")

        print(f"  {r['key']:<{KW}} {val_str:<{VW + (10 if changed else 0)}}  {def_str}")
    print()
    print(_c("  Yellow = changed from default", "grey"))
    print()


